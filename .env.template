# ============================================================================
# Azure AutoML - Sales Forecasting Project
# Environment Configuration Template
# ============================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.template .env
#   2. Fill in your Azure credentials below
#   3. Never commit .env to git (it's in .gitignore)
# ============================================================================

# --- Azure Subscription ---
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=sales-forecasting-rg
AZURE_REGION=westus2

# --- Azure Machine Learning Workspace ---
AML_WORKSPACE_NAME=sales-forecast-ws

# --- Compute Configuration ---
# Standard_DS3_v2 is cost-effective for AutoML time-series
# Cluster auto-scales from 0 (no cost when idle) to max_nodes
AML_COMPUTE_NAME=forecast-cluster
AML_COMPUTE_SIZE=Standard_DS3_v2
AML_COMPUTE_MIN_NODES=0
AML_COMPUTE_MAX_NODES=4

# --- AutoML Experiment Settings ---
EXPERIMENT_NAME=store-sales-forecasting
FORECAST_HORIZON=90
PRIMARY_METRIC=normalized_root_mean_squared_error
TRAINING_TIMEOUT_HOURS=2

# --- Endpoint Deployment ---
ENDPOINT_NAME=sales-forecast-endpoint
DEPLOYMENT_NAME=sales-forecast-deploy
DEPLOYMENT_INSTANCE_TYPE=Standard_DS3_v2
DEPLOYMENT_INSTANCE_COUNT=1

# --- Kaggle Dataset ---
# Option 1: Download manually from https://www.kaggle.com/competitions/store-sales-time-series-forecasting
# Option 2: Use Kaggle API (requires ~/.kaggle/kaggle.json)
KAGGLE_DATASET=store-sales-time-series-forecasting
