# Environment & Secrets
.env
*.pem
*.key

# Data files (too large for git)
data/raw/*.csv
data/processed/*.csv
data/output/*.csv
data/output/*.parquet

# Allow parquet files for Streamlit Cloud deployment
!data/processed/fact_sales.parquet
!data/processed/fact_forecasts.parquet

# Allow small dimension CSVs
!data/processed/dim_date.csv
!data/processed/dim_store.csv
!data/processed/dim_product.csv

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/output/.gitkeep

# Allow training results JSON
!data/output/training_results.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata

# Power BI
# Include .pbix for portfolio purposes
# *.pbix

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Models (large binary files)
models/*.joblib
models/*.pkl

# Azure ML
azureml-models/
outputs/
logs/
